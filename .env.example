# YouTube / Google OAuth
# Download credentials.json from Google Cloud Console → APIs & Services → Credentials

# X / Twitter API
# Get from: developer.twitter.com → your app → Keys and Tokens
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# Meta (Facebook + Instagram)
# Get from: developers.facebook.com → your app → Graph API
META_ACCESS_TOKEN=your_long_lived_token_here
FACEBOOK_PAGE_ID=your_page_id_here
INSTAGRAM_BUSINESS_ID=your_instagram_business_account_id_here

# TikTok
# Get from: developers.tiktok.com → your app → Manage Apps
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here
TIKTOK_ACCESS_TOKEN=your_access_token_here
